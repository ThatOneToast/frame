{
  "name": "@frame/svelte",
  "version": "0.1.0",
  "description": "Svelte and Vite integration for the Frame CSS DSL",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./vite": {
      "types": "./dist/src/vite.d.ts",
      "import": "./dist/src/vite.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0",
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
