component MediaCard {
  view {
    card MediaCard {
      image CoverPicture {
        sources "/media/cover.avif"
        alt "Product preview"
      }

      media PreviewVideo {
        sources "/media/preview.mp4"
        poster "/media/poster.jpg"
      }

      label Caption {
        text "A media card with safe URL attributes."
      }
    }
  }
}
