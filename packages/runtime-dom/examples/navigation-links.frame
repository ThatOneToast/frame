component NavigationLinks {
  view {
    menu MainNavigation:NavigationShell {
      label "Primary navigation"

      stack NavigationItems {
        item HomeItem {
          link Home {
            goto "/"
            text "Home"
          }
        }

        item DocsItem {
          link Docs {
            goto "/docs"
            text "Docs"
          }
        }
      }
    }
  }
}

stack NavigationShell {
  gap small
  padding medium
  surface panel
}
