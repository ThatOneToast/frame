component NavigationLinks {
  view {
    menu MainNav {
      label "Primary"

      list NavList {
        item HomeItem {
          link HomeLink {
            goto "/"
            text "Home"
          }
        }

        item DocsItem {
          link DocsLink {
            goto "https://example.com/docs"
            text "Docs"
          }
        }
      }
    }
  }
}
