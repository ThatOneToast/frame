component SettingsDialog {
  state {
    open bool = true
    compact bool = false
  }

  view {
    dialog SettingsModal {
      show when $open

      title SettingsTitle {
        text "Settings"
      }

      composer SettingsForm {
        on submit @save

        toggle CompactToggle {
          label "Compact mode"
          checked bind $compact
        }

        action SaveButton {
          text "Save"
          on press @save
        }
      }
    }
  }
}
