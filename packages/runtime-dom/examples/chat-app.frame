component MessageItem {
  props {
    title string
  }

  view {
    card Message {
      text $title
    }
  }
}

component ChatApp {
  state {
    messages list = []
  }

  view {
    screen ChatMain {
      for message in $messages key $message.id {
        MessageItem(title: $message.text)
      }
    }
  }
}
