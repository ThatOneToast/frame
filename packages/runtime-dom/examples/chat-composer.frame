component ChatComposer {
  state {
    draft string = ""
    sending bool = false
  }

  view {
    composer ComposerForm {
      label "Message composer"
      on submit @send
      on reset @clear

      editor DraftInput {
        label "Message"
        value bind $draft
        on input @updateDraft
        on keydown.enter @send
      }

      action SendButton {
        disabled when $sending
        text "Send"
        on press @send
      }
    }
  }
}
