// LLM Dashboard Theme - Dark Glassy Design System

html {
  background #0A0A0F
  color #F8FAFC
}

page-body {
  margin none
  background #0A0A0F
  color #F8FAFC
}

tokens DashboardTokens {
  color background #0A0A0F
  color surface #12121A
  color surface-raised #1A1A24
  color surface-overlay #22222E
  color border #2A2A36
  color border-accent #3B82F6
  color text-primary #F8FAFC
  color text-secondary #94A3B8
  color text-muted #64748B
  color accent #3B82F6
  color accent-hover #2563EB
  color success #22C55E
  color warning #F59E0B
  color danger #EF4444
  color info #06B6D4
}

// App Layout
grid AppShell {
  tracks columns panel fill
  tracks rows auto fill
  gap none
  height screen
}

area Header {
  in AppShell
  row 1
  span 2
  surface panel
  padding medium
  align center
  justify between
  border soft
}

area Sidebar {
  in AppShell
  row 2
  col 1
  surface panel
  padding medium
  border soft
}

area Main {
  in AppShell
  row 2
  col 2
  padding medium
}

// Navigation Styles
row NavBar {
  gap large
  align center
  justify between
  color text-primary
  padding small
}

stack Logo {
  padding small
  gap small
  color text-primary
  weight bold
  size large
}

row SearchBar {
  padding medium
  surface raised
  radius medium
  gap medium
  color text-muted
  border soft
}

row UserInfo {
  padding small
  gap small
  color text-secondary
}

stack SidebarNav {
  surface panel
  padding medium
  border soft
}

stack Navigation {
  gap medium
  padding medium
  color text-primary
}

stack NavSection {
  gap small
  padding small
  color text-secondary
}

// Nav item styling
text NavItem {
  padding small
  radius small
  color text-secondary
  transition smooth
}

// Main Content
stack MainContent {
  surface main
  padding medium
  color text-primary
}

// Dashboard Grid
grid DashboardContent {
  columns content
  gap medium
}

// Metric Cards
row MetricRow {
  gap medium
  align center
}

card MetricCard {
  surface raised
  padding medium
  radius medium
  border soft
  shadow small
  color text-primary
  transition smooth
  hover {
    lift small
    glow soft
  }
}

stack MetricContent {
  gap small
  padding small
  color text-secondary
}

// Performance Section
grid PerformanceGrid {
  columns chart prompt
  gap medium
  below mobile {
    columns content
  }
}

card PerformanceChart {
  surface raised
  padding medium
  radius medium
  border soft
  color text-primary
}

stack ChartHeader {
  gap small
  padding small
}

row ChartTitle {
  gap medium
  align center
  color text-primary
}

row ChartLegend {
  gap medium
  align center
  color text-muted
}

stack ChartArea {
  padding medium
  color text-muted
}

card RunPrompt {
  surface raised
  padding medium
  radius medium
  border soft
  color text-primary
}

stack PromptContent {
  gap medium
  padding medium
}

stack PromptInput {
  padding medium
  surface overlay
  radius medium
  color text-muted
  border soft
}

button PrimaryButton {
  surface accent
  padding medium
  radius medium
  color text-primary
  transition smooth
  hover {
    glow soft
  }
}

// Inference Runs Table
grid DashboardGrid {
  columns runs models
  gap medium
  below mobile {
    columns content
  }
}

card InferenceRuns {
  surface raised
  padding medium
  radius medium
  border soft
  color text-primary
}

stack RunsHeader {
  gap small
  padding small
  color text-primary
}

row RunTabs {
  gap small
  padding small
}

button TabAll {
  padding small
  radius small
  surface overlay
  color text-primary
  border soft
  transition smooth
}

button TabLocal {
  padding small
  radius small
  surface overlay
  color text-primary
  border soft
  transition smooth
}

button TabRemote {
  padding small
  radius small
  surface overlay
  color text-primary
  border soft
  transition smooth
}

stack RunsTable {
  gap small
  padding small
}

row RunRow {
  gap medium
  padding small
  align center
  border soft
  color text-secondary
  transition smooth
  hover {
    lift small
  }
}

// Top Models Panel
card TopModels {
  surface raised
  padding medium
  radius medium
  border soft
  color text-primary
}

stack ModelsHeader {
  gap small
  padding small
  color text-primary
}

stack ModelsList {
  gap small
  padding small
}

row ModelRow {
  gap medium
  padding small
  align center
  justify between
  color text-secondary
  border soft
  transition smooth
  hover {
    lift small
  }
}
