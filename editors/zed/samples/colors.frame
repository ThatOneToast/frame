tokens Brand {
  color brand #7c3aed
  color brand-muted #a78bfa
  color page-bg #0f0f14
  color panel-bg #181820
}

card BrandCard {
  background brand
  color white
  border brand-muted
  surface raised
  text bright
}

card AlertCard {
  background panel-bg
  border warning
  glow warning
  color cyan
}
