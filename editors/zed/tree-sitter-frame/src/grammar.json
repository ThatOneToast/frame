          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "state_keyword"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "property",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "property_keyword"
              },
              {
                "type": "SYMBOL",
                "name": "effect_keyword"
              },
              {
                "type": "SYMBOL",
                "name": "identifier"
              }
            ]
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "value",
            "content": {
              "type": "SYMBOL",
              "name": "value"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "declaration_name": {
      "type": "SYMBOL",
