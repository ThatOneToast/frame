{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "frame",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "declaration"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "kind",
          "content": {
            "type": "SYMBOL",
            "name": "declaration_keyword"
          }
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "declaration_name"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_newline"
              },
              {
                "type": "SYMBOL",
                "name": "state_block"
              },
              {
                "type": "SYMBOL",
                "name": "statement"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "state_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "state_keyword"
          }
        },
        {
          "type": "SYMBOL",
          "name": "block"
        }
      ]
    },
    "statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "property",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "property_keyword"
              },
              {
                "type": "SYMBOL",
                "name": "effect_keyword"
              },
              {
                "type": "SYMBOL",
                "name": "identifier"
              }
            ]
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "FIELD",
            "name": "value",
            "content": {
              "type": "SYMBOL",
              "name": "identifier"
            }
          }
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "declaration_name": {
      "type": "SYMBOL",
      "name": "identifier"
    },
    "declaration_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "tokens"
        },
        {
          "type": "STRING",
          "value": "grid"
        },
        {
          "type": "STRING",
          "value": "area"
        },
        {
          "type": "STRING",
          "value": "card"
        },
        {
          "type": "STRING",
          "value": "stack"
        },
        {
          "type": "STRING",
          "value": "row"
        },
        {
          "type": "STRING",
          "value": "button"
        },
        {
          "type": "STRING",
          "value": "text"
        }
      ]
    },
    "state_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "hover"
        },
        {
          "type": "STRING",
          "value": "focus"
        },
        {
          "type": "STRING",
          "value": "active"
        }
      ]
    },
    "property_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "columns"
        },
        {
          "type": "STRING",
          "value": "rows"
        },
        {
          "type": "STRING",
          "value": "gap"
        },
        {
          "type": "STRING",
          "value": "height"
        },
        {
          "type": "STRING",
          "value": "width"
        },
        {
          "type": "STRING",
          "value": "surface"
        },
        {
          "type": "STRING",
          "value": "background"
        },
        {
          "type": "STRING",
          "value": "theme"
        },
        {
          "type": "STRING",
          "value": "padding"
        },
        {
          "type": "STRING",
          "value": "margin"
        },
        {
          "type": "STRING",
          "value": "radius"
        },
        {
          "type": "STRING",
          "value": "border"
        },
        {
          "type": "STRING",
          "value": "shadow"
        },
        {
          "type": "STRING",
          "value": "place"
        },
        {
          "type": "STRING",
          "value": "in"
        },
        {
          "type": "STRING",
          "value": "col"
        },
        {
          "type": "STRING",
          "value": "row"
        },
        {
          "type": "STRING",
          "value": "span"
        }
      ]
    },
    "effect_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "lift"
        },
        {
          "type": "STRING",
          "value": "glow"
        },
        {
          "type": "STRING",
          "value": "brighten"
        },
        {
          "type": "STRING",
          "value": "dim"
        },
        {
          "type": "STRING",
          "value": "blur"
        },
        {
          "type": "STRING",
          "value": "press"
        },
        {
          "type": "STRING",
          "value": "ring"
        },
        {
          "type": "STRING",
          "value": "smooth"
        }
      ]
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_-]*"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}